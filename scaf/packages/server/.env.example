# ================================================================
# .env.example — HAULOPS Server (Production)
# Salin file ini menjadi .env dan isi nilainya
# JANGAN commit file .env ke Git!
# ================================================================

# ------- DATABASE (Supabase) -------
# Ambil dari: Supabase Dashboard > Project Settings > Database > Connection String
# GUNAKAN "Transaction pooler" (port 6543) untuk environment production/Render
# GUNAKAN "Session pooler" atau direct URL untuk prisma migrate / prisma db seed
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# URL ini KHUSUS untuk prisma migrate deploy (butuh koneksi langsung, bukan pooler)
# Ambil dari: Supabase Dashboard > Project Settings > Database > Connection String > Session Pooler (port 5432) atau Direct Connection
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# ------- AUTH -------
JWT_SECRET="ganti-dengan-string-acak-minimum-32-karakter"
JWT_EXPIRES_IN="8h"

# ------- ADMIN AWAL (bootstrap first-run) -------
# Saat DB production baru & kosong, server otomatis membuat 1 akun admin agar
# bisa login. Hanya berjalan bila belum ada user (idempoten). ISI ADMIN_PASSWORD
# di production — bila kosong, dipakai default 'admin' (tidak aman, ganti segera).
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="ganti-password-kuat"
ADMIN_BRANCH_KODE="HQ"
ADMIN_BRANCH_NAMA="Kantor Pusat"

# ------- SERVER -------
PORT=4001
NODE_ENV=production

# ------- CORS -------
# URL frontend di Railway, contoh:
CORS_ORIGIN="https://haulops-web.up.railway.app"
